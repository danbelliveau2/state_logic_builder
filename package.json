{
  "name": "sdc-state-logic-builder",
  "version": "1.23.1",
  "description": "SDC State Logic Diagram Builder - ME to L5X",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "node server.js",
    "electron:dev": "electron .",
    "electron:build": "electron-builder --win portable",
    "electron:installer": "electron-builder --win nsis"
  },
  "dependencies": {
    "@xyflow/react": "^12.3.0",
    "electron-updater": "^6.8.3",
    "nanoid": "^5.0.7",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.sdc.statelogicbuilder",
    "productName": "SDC State Logic Builder",
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "dist"
      },
      {
        "from": "server.js",
        "to": "server.js"
      },
      {
        "from": "public/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "icon": "public/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SDC State Logic Builder",
      "artifactName": "SDC-State-Logic-Builder-Setup-${version}.exe"
    },
    "publish": {
      "provider": "github",
      "owner": "danbelliveau2",
      "repo": "state_logic_builder",
      "releaseType": "release"
    },
    "directories": {
      "output": "release"
    }
  }
}
