<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Part_Locate Vertical_Cylinder Extend Timeout]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[10])TON(SensorTimer[0],?,?)XIC(SensorTimer[0].DN) ,XIC(Alarm[0].Active) XIO(FaultReset) ]OTE(Alarm[0].Active);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Part_Locate Part_Gripper Engage Timeout]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[13])TON(SensorTimer[1],?,?)XIC(SensorTimer[1].DN) ,XIC(Alarm[1].Active) XIO(FaultReset) ]OTE(Alarm[1].Active);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Part_Locate Part_Push Motion Timeout]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[16])TON(SensorTimer[2],?,?)XIC(SensorTimer[2].DN) ,XIC(Alarm[2].Active) XIO(FaultReset) ]OTE(Alarm[2].Active);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Part_Locate Part_Push Motion Timeout]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[19])TON(SensorTimer[3],?,?)XIC(SensorTimer[3].DN) ,XIC(Alarm[3].Active) XIO(FaultReset) ]OTE(Alarm[3].Active);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Part_Locate Part_Gripper Disengage Timeout]]>
</Comment>
