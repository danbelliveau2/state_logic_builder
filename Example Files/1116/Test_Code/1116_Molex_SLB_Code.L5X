<Routine Name="R00_Main" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Subroutine Calls]]>
</Comment>
<Text>
<![CDATA[JSR(R01_Inputs,0);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[JSR(R02_StateTransitions,0);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[JSR(R03_StateLogic,0);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[JSR(R20_Alarms,0);]]>
</Text>
</Rung>
</RLLContent>
</Routine>

<Routine Name="R01_Inputs" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Mapped Inputs from Supervisor]]>
</Comment>
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIC(\Supervisor.q_ManualMode)XIO(HMI_LocalManualOverride)OTE(ManualMode);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIC(\Supervisor.q_SafetyOK)OTE(SafetyOK);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[XIC(\Supervisor.q_FaultReset)OTE(FaultReset);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[[XIC(\Supervisor.q_CycleStartLatch) ,XIC(HMI_LocalManualOverride) ]OTE(CycleRunning);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[XIO(\Supervisor.q_CycleStartLatch)OTE(CycleStopping);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[XIC(\Supervisor.q_CycleStopped)ONS(ONS.0)XIO(Status.State[2])XIO(Status.State[3])OTE(CycleStopped);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Initialization]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[124])OTE(Initialized);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[Single Step Logic]]>
</Comment>
<Text>
<![CDATA[XIC(LocalSS)OTE(SS);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Text>
<![CDATA[[XIO(SS) ,XIC(LocalSSONS) ONS(ONS.1) ]OTE(SS_OK);]]>
</Text>
</Rung>
</RLLContent>
</Routine>

<Routine Name="R02_StateTransitions" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[State 0: Safety Stop]]>
</Comment>
<Text>
<![CDATA[[XIO(SafetyOK) ,XIC(S:FS) ][ONS(ONS.3) LIMIT(4,Control.StateReg,99) MOVE(Control.StateReg,SafetyStopState) MOVE(Control.StateReg,RestartState) ,MOVE(0,Control.StateReg) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[State 1: Manual Mode]]>
</Comment>
<Text>
<![CDATA[XIC(ManualMode)MOVE(1,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[State 2: Auto Idle NOT Ready]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[0]) XIC(SafetyOK) XIO(ManualMode) ,XIC(Status.State[1]) XIO(ManualMode) ,XIC(Status.State[127]) XIC(FaultReset) ,XIC(Status.State[124]) ]MOVE(2,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[State 3: Auto Idle Ready]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[2]) XIC(Initialized) ,XIC(Status.State[22]) ]MOVE(3,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[State 127: Fault]]>
</Comment>
<Text>
<![CDATA[XIC(q_AlarmActive)[ONS(ONS.2) LIMIT(4,Control.StateReg,99) MOVE(Control.StateReg,FaultState) MOVE(Control.StateReg,RestartState) ,MOVE(127,Control.StateReg) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[State 4: Home]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[3])XIC(CycleRunning)MOVE(4,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[State 7: Wait: IndexComplete]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[4])MOVE(7,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[State 10: Temperature_Verify Camera Inspect Temperature_Verify_Inspect]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[7])MOVE(10,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[State 13: Temperature_Verify Camera - Wait Timer]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[10])XIC(i_Temperature_VerifyCamTrigRdy)MOVE(13,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[State 16: Temperature_Verify Camera - Trigger]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[13])TON(Temperature_VerifyCamTrigDwell,?,?)XIC(Temperature_VerifyCamTrigDwell.DN)MOVE(16,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[State 19: Temperature_Verify Camera - Check Results]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[16])XIC(i_Temperature_VerifyCamResultReady)MOVE(19,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Comment>
<![CDATA[State 22: Cycle Complete [branch]]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[19])XIC(i_Temperature_VerifyCamInspPass)MOVE(22,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[Cycle Time Accumulator]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[4]) ,XIC(Status.State[7]) ,XIC(Status.State[10]) ,XIC(Status.State[22])]RTO(CycleTimer,?,?);]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Comment>
<![CDATA[Cycle Time Compute + Reset]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[3])XIC(CycleRunning)ONS(ONS.4)[DIV(CycleTimer.ACC,1000.0,p_CycleTime) ,MOVE(0,CycleTimer.ACC) ];]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Comment>
<![CDATA[Fault Timer Enable]]>
</Comment>
<Text>
<![CDATA[LIMIT(4,Control.StateReg,59)XIO(SS)[MOVE(5000,Control.FaultTime) ,OTE(Control.EnaFaultDetect) ];]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Comment>
<![CDATA[State Engine]]>
</Comment>
<Text>
<![CDATA[State_Engine_128Max(StateEngine,Control,Status,StateHistory);]]>
</Text>
</Rung>
</RLLContent>
</Routine>

<Routine Name="R03_StateLogic" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Part Tracking: Clear All at Cycle Start]]>
</Comment>
<Text>
<![CDATA[XIC(CycleRunning)ONS(ONS.5)OTU(PartTracking.Location_Verify_Inspect)OTU(PartTracking.Location_Verify_Inspect_X_Offset)OTU(PartTracking.Temperature_Verify_Inspect);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Temperature_Verify Camera Camera Trigger]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[16])OTE(q_TriggerTemperature_VerifyCam);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Station Start OK]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[1]) ,XIC(Status.State[2]) ,XIC(Status.State[3]) ]XIO(q_AlarmActive)OTE(q_StartOK);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Auto Mode Status]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[2]) ,XIC(Status.State[3]) ]XIO(CycleRunning)OTE(q_AutoMode);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Auto Stopped Status]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[2]) ,XIC(Status.State[3]) ,XIC(Status.State[127]) ]XIO(CycleRunning)OTE(q_AutoStopped);]]>
</Text>
</Rung>
</RLLContent>
</Routine>

<Routine Name="R20_Alarms" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[No fault conditions defined]]>
</Comment>
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program Alarm Handler]]>
</Comment>
<Text>
<![CDATA[ProgramAlarmHandler(ProgramFaultHandler,\Alarms.p_ProgramID,Alarm,\Alarms.p_Active,\Alarms.p_History,g_CPUDateTime,q_AlarmActive,q_WarningActive);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
</Program>
