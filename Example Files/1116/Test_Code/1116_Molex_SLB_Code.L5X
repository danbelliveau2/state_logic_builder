<![CDATA[[XIC(Status.State[19])TON(SensorTimer[4],?,?)XIC(SensorTimer[4].DN) ,XIC(Alarm[4].Active) XIO(FaultReset) ]OTE(Alarm[4].Active);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
