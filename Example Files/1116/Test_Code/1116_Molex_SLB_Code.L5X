<Routines>
<Routine Name="Logic" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Text>
<![CDATA[[ADD(Value,Deadband,Max) ,SUB(Value,Deadband,Min) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[LIMIT(Min,Actual,Max)OTE(In_Range);]]>
</Text>
</Rung>
</RLLContent>
