<Routines>

<Routine Name="R00_Main" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Subroutine Calls]]>
</Comment>
<Text>
<![CDATA[JSR(R01_Inputs,0);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[JSR(R02_StateTransitions,0);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[JSR(R03_StateLogic,0);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[JSR(R20_Alarms,0);]]>
</Text>
</Rung>
</RLLContent>
</Routine>

<Routine Name="R01_Inputs" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Mapped Inputs from Supervisor]]>
</Comment>
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIC(\Supervisor.q_ManualMode)XIO(HMI_LocalManualOverride)OTE(ManualMode);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIC(\Supervisor.q_SafetyOK)OTE(SafetyOK);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[XIC(\Supervisor.q_FaultReset)OTE(FaultReset);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[[XIC(\Supervisor.q_CycleStartLatch) ,XIC(HMI_LocalManualOverride) ]OTE(CycleRunning);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[XIO(\Supervisor.q_CycleStartLatch)OTE(CycleStopping);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[XIC(\Supervisor.q_CycleStopped)ONS(ONS.0)XIO(Status.State[2])XIO(Status.State[3])OTE(CycleStopped);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Initialization]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[124])OTE(Initialized);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[Single Step Logic]]>
</Comment>
<Text>
<![CDATA[XIC(LocalSS)OTE(SS);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Text>
<![CDATA[[XIO(SS) ,XIC(LocalSSONS) ONS(ONS.1) ]OTE(SS_OK);]]>
</Text>
</Rung>
</RLLContent>
</Routine>

<Routine Name="R02_StateTransitions" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[State 0: Safety Stop]]>
</Comment>
<Text>
<![CDATA[[XIO(SafetyOK) ,XIC(S:FS) ][ONS(ONS.3) LIMIT(4,Control.StateReg,99) MOVE(Control.StateReg,SafetyStopState) MOVE(Control.StateReg,RestartState) ,MOVE(0,Control.StateReg) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[State 1: Manual Mode]]>
</Comment>
<Text>
<![CDATA[XIC(ManualMode)MOVE(1,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[State 2: Auto Idle NOT Ready]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[0]) XIC(SafetyOK) XIO(ManualMode) ,XIC(Status.State[1]) XIO(ManualMode) ,XIC(Status.State[127]) XIC(FaultReset) ,XIC(Status.State[124]) ]MOVE(2,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[State 3: Auto Idle Ready]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[2]) XIC(Initialized) ,XIC(Status.State[13]) ]MOVE(3,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[State 127: Fault]]>
</Comment>
<Text>
<![CDATA[XIC(q_AlarmActive)[ONS(ONS.2) LIMIT(4,Control.StateReg,99) MOVE(Control.StateReg,FaultState) MOVE(Control.StateReg,RestartState) ,MOVE(127,Control.StateReg) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[State 4: Home]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[3])XIC(CycleRunning)XIC(MAM_DialIndexer.PC)MOVE(4,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[State 7: Wait: AllStationsReady]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[4])MOVE(7,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[State 10: Index Dial_Indexer — Index (1-pos)]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[7])MOVE(10,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[State 13: Cycle Complete]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[10])XIC(MAM_DialIndexer.PC)MOVE(13,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[Cycle Time Accumulator]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[4]) ,XIC(Status.State[7]) ,XIC(Status.State[10]) ,XIC(Status.State[13])]RTO(CycleTimer,?,?);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[Cycle Time Compute + Reset]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[3])XIC(CycleRunning)ONS(ONS.4)[DIV(CycleTimer.ACC,1000.0,p_CycleTime) ,MOVE(0,CycleTimer.ACC) ];]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Comment>
<![CDATA[Fault Timer Enable]]>
</Comment>
<Text>
<![CDATA[LIMIT(4,Control.StateReg,59)XIO(SS)[MOVE(5000,Control.FaultTime) ,OTE(Control.EnaFaultDetect) ];]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[State Engine]]>
</Comment>
<Text>
<![CDATA[State_Engine_128Max(StateEngine,Control,Status,StateHistory);]]>
</Text>
</Rung>
</RLLContent>
</Routine>

<Routine Name="R03_StateLogic" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Part Tracking: Clear All at Cycle Start]]>
</Comment>
<Text>
<![CDATA[XIC(CycleRunning)ONS(ONS.5)OTU(PartTracking.Location_Verify_Inspect)OTU(PartTracking.Location_Verify_Inspect_X_Offset)OTU(PartTracking.Temperature_Verify_Inspect);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Dial_Indexer Position Selection]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[10]) [MOVE(p_DialIndexerIndexAngle,DialIndexer_MotionParam.Position) ,MOVE(1,DialIndexer_MotionParam.MoveType) ] ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Dial_Indexer Motion Command]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[10])MAM(a{axisNum}_DialIndexer,MAM_DialIndexer,DialIndexer_MotionParam.MoveType,DialIndexer_MotionParam.Position,DialIndexer_MotionParam.Speed,Units per sec,DialIndexer_MotionParam.Accel,Units per sec2,DialIndexer_MotionParam.Decel,Units per sec2,Trapezoidal,0,0,Units per sec3,Disabled,0,0,None,0,0);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Dial_Indexer Position Monitoring]]>
</Comment>
<Text>
<![CDATA[[AOI_RangeCheck(DialIndexerIndexRC,p_DialIndexerIndex,0.5,a{axisNum}_DialIndexer.ActualPosition) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Station Start OK]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[1]) ,XIC(Status.State[2]) ,XIC(Status.State[3]) ]XIO(q_AlarmActive)OTE(q_StartOK);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Auto Mode Status]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[2]) ,XIC(Status.State[3]) ]XIO(CycleRunning)OTE(q_AutoMode);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Auto Stopped Status]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[2]) ,XIC(Status.State[3]) ,XIC(Status.State[127]) ]XIO(CycleRunning)OTE(q_AutoStopped);]]>
</Text>
</Rung>
</RLLContent>
</Routine>

<Routine Name="R20_Alarms" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Dial_Indexer Motion Timeout]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[10])TON(SensorTimer[0],?,?)XIC(SensorTimer[0].DN) ,XIC(Alarm[0].Active) XIO(FaultReset) ]OTE(Alarm[0].Active);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Program Alarm Handler]]>
</Comment>
<Text>
<![CDATA[ProgramAlarmHandler(ProgramFaultHandler,\Alarms.p_ProgramID,Alarm,\Alarms.p_Active,\Alarms.p_History,g_CPUDateTime,q_AlarmActive,q_WarningActive);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
</Program>
</Programs>
<Tasks>
<Task Name="MainTask" Type="CONTINUOUS" Rate="10" Priority="10" Watchdog="500">
<ScheduledPrograms>
          <ScheduledProgram Name="MainProgram"/>
          <ScheduledProgram Name="Supervisor"/>
          <ScheduledProgram Name="S01_RobotLoad"/>
          <ScheduledProgram Name="S01_PartLoad"/>
          <ScheduledProgram Name="S04_PartLocate"/>
          <ScheduledProgram Name="S06_LocationVerify"/>
          <ScheduledProgram Name="S07_Reject1Unload"/>
          <ScheduledProgram Name="S17_BarrelVerify"/>
          <ScheduledProgram Name="S21_Reject2Unload"/>
          <ScheduledProgram Name="S55_TemperatureVerify"/>
          <ScheduledProgram Name="S56_WireFeed"/>
          <ScheduledProgram Name="S61_WireFeedVerify"/>
          <ScheduledProgram Name="S72_GoodPartUnload1"/>
          <ScheduledProgram Name="S76_GoodPartUnload2"/>
          <ScheduledProgram Name="S84_RejectPartUnload"/>
          <ScheduledProgram Name="S99_DialIndexer"/>
</ScheduledPrograms>
</Task>
</Tasks>
</Controller>
</RSLogix5000Content>