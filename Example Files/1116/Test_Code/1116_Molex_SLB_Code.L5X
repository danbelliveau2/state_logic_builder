<Routine Name="R01_Inputs" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Mapped Inputs from Supervisor]]>
</Comment>
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIC(\Supervisor.q_ManualMode)XIO(HMI_LocalManualOverride)OTE(ManualMode);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIC(\Supervisor.q_SafetyOK)OTE(SafetyOK);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[XIC(\Supervisor.q_FaultReset)OTE(FaultReset);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[[XIC(\Supervisor.q_CycleStartLatch) ,XIC(HMI_LocalManualOverride) ]OTE(CycleRunning);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[XIO(\Supervisor.q_CycleStartLatch)OTE(CycleStopping);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[XIC(\Supervisor.q_CycleStopped)ONS(ONS.0)XIO(Status.State[2])XIO(Status.State[3])OTE(CycleStopped);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Initialization]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[124])OTE(Initialized);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[Single Step Logic]]>
</Comment>
<Text>
<![CDATA[XIC(LocalSS)OTE(SS);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Text>
<![CDATA[[XIO(SS) ,XIC(LocalSSONS) ONS(ONS.1) ]OTE(SS_OK);]]>
</Text>
</Rung>
</RLLContent>
</Routine>

<Routine Name="R02_StateTransitions" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[State 0: Safety Stop]]>
</Comment>
<Text>
<![CDATA[[XIO(SafetyOK) ,XIC(S:FS) ][ONS(ONS.3) LIMIT(4,Control.StateReg,99) MOVE(Control.StateReg,SafetyStopState) MOVE(Control.StateReg,RestartState) ,MOVE(0,Control.StateReg) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[State 1: Manual Mode]]>
</Comment>
<Text>
<![CDATA[XIC(ManualMode)MOVE(1,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[State 2: Auto Idle NOT Ready]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[0]) XIC(SafetyOK) XIO(ManualMode) ,XIC(Status.State[1]) XIO(ManualMode) ,XIC(Status.State[127]) XIC(FaultReset) ,XIC(Status.State[124]) ]MOVE(2,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[State 3: Auto Idle Ready]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[2]) XIC(Initialized) ,XIC(Status.State[25]) ]MOVE(3,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[State 127: Fault]]>
</Comment>
<Text>
<![CDATA[XIC(q_AlarmActive)[ONS(ONS.2) LIMIT(4,Control.StateReg,99) MOVE(Control.StateReg,FaultState) MOVE(Control.StateReg,RestartState) ,MOVE(127,Control.StateReg) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[State 4: Home]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[3])XIC(CycleRunning)TON(Part_LocatePart_GripperDisengageDelay,?,?)XIC(Part_LocatePart_GripperDisengageDelay.DN)XIC(i_Part_LocateVertical_CylinderRet)XIO(i_Part_LocateVertical_CylinderExt)XIC(MAM_Part_LocatePart_Push.PC)MOVE(4,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[State 7: Wait: IndexComplete]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[4])MOVE(7,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[State 10: Extend Part_Locate Vertical_Cylinder]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[7])MOVE(10,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[State 13: Engage Part_Locate Part_Gripper]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[10])XIC(i_Part_LocateVertical_CylinderExt)XIO(i_Part_LocateVertical_CylinderRet)MOVE(13,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[State 16: Move Part_Locate Part_Push to Work]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[13])TON(Part_LocatePart_GripperEngageDelay,?,?)XIC(Part_LocatePart_GripperEngageDelay.DN)MOVE(16,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[State 19: Move Part_Locate Part_Push to Home, Disengage Part_Locate Part_Gripper]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[16])XIC(MAM_Part_LocatePart_Push.PC)XIC(Part_LocatePart_PushWorkRC.In_Range)MOVE(19,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Comment>
<![CDATA[State 22: Retract Part_Locate Vertical_Cylinder]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[19])XIC(MAM_Part_LocatePart_Push.PC)XIC(Part_LocatePart_PushHomeRC.In_Range)TON(Part_LocatePart_GripperDisengageDelay,?,?)XIC(Part_LocatePart_GripperDisengageDelay.DN)MOVE(22,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[State 25: Cycle Complete]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[22])XIC(i_Part_LocateVertical_CylinderRet)XIO(i_Part_LocateVertical_CylinderExt)MOVE(25,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Comment>
<![CDATA[Cycle Time Accumulator]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[4]) ,XIC(Status.State[7]) ,XIC(Status.State[10]) ,XIC(Status.State[13]) ,XIC(Status.State[16]) ,XIC(Status.State[19]) ,XIC(Status.State[22]) ,XIC(Status.State[25])]RTO(CycleTimer,?,?);]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Comment>
<![CDATA[Cycle Time Compute + Reset]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[3])XIC(CycleRunning)ONS(ONS.4)[DIV(CycleTimer.ACC,1000.0,p_CycleTime) ,MOVE(0,CycleTimer.ACC) ];]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Comment>
<![CDATA[Fault Timer Enable]]>
</Comment>
<Text>
<![CDATA[LIMIT(4,Control.StateReg,59)XIO(SS)[MOVE(5000,Control.FaultTime) ,OTE(Control.EnaFaultDetect) ];]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Comment>
<![CDATA[State Engine]]>
</Comment>
<Text>
<![CDATA[State_Engine_128Max(StateEngine,Control,Status,StateHistory);]]>
</Text>
</Rung>
</RLLContent>
</Routine>

<Routine Name="R03_StateLogic" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Part_Locate Part_Gripper Control]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[13]) ,XIC(ManualMode) XIC(HMI_Button.0) ,XIC(q_EngagePart_LocatePart_Gripper) [XIO(ManualMode) XIO(Status.State[1]) XIO(Status.State[19]) ,XIC(ManualMode) XIO(HMI_Button.1)] ]OTE(q_EngagePart_LocatePart_Gripper);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIO(q_EngagePart_LocatePart_Gripper)OTE(q_DisengagePart_LocatePart_Gripper);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Part_Locate Vertical_Cylinder Control]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[10]) ,XIC(ManualMode) XIC(HMI_Button.2) ,XIC(q_ExtPart_LocateVertical_Cylinder) [XIO(ManualMode) XIO(Status.State[1]) XIO(Status.State[22]) ,XIC(ManualMode) XIO(HMI_Button.3)] ]OTE(q_ExtPart_LocateVertical_Cylinder);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[XIO(q_ExtPart_LocateVertical_Cylinder)OTE(q_RetPart_LocateVertical_Cylinder);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Part Tracking: Clear All at Cycle Start]]>
</Comment>
<Text>
<![CDATA[XIC(CycleRunning)ONS(ONS.5)OTU(PartTracking.Location_Verify_Inspect)OTU(PartTracking.Location_Verify_Inspect_X_Offset)OTU(PartTracking.Temperature_Verify_Inspect);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Part_Locate Part_Push Position Selection]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[16]) [MOVE(p_Part_LocatePart_PushWork,Part_LocatePart_Push_MotionParam.Position) ,MOVE(0,Part_LocatePart_Push_MotionParam.MoveType) ] ,XIC(Status.State[19]) [MOVE(p_Part_LocatePart_PushHome,Part_LocatePart_Push_MotionParam.Position) ,MOVE(0,Part_LocatePart_Push_MotionParam.MoveType) ] ];]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Part_Locate Part_Push Motion Command]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[16]) ,XIC(Status.State[19])]MAM(a{axisNum}_Part_LocatePart_Push,MAM_Part_LocatePart_Push,Part_LocatePart_Push_MotionParam.MoveType,Part_LocatePart_Push_MotionParam.Position,Part_LocatePart_Push_MotionParam.Speed,Units per sec,Part_LocatePart_Push_MotionParam.Accel,Units per sec2,Part_LocatePart_Push_MotionParam.Decel,Units per sec2,Trapezoidal,0,0,Units per sec3,Disabled,0,0,None,0,0);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Part_Locate Part_Push Position Monitoring]]>
</Comment>
<Text>
<![CDATA[[AOI_RangeCheck(Part_LocatePart_PushHomeRC,p_Part_LocatePart_PushHome,0.5,a{axisNum}_Part_LocatePart_Push.ActualPosition) ,AOI_RangeCheck(Part_LocatePart_PushPushRC,p_Part_LocatePart_PushPush,0.5,a{axisNum}_Part_LocatePart_Push.ActualPosition) ];]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[Station Start OK]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[1]) ,XIC(Status.State[2]) ,XIC(Status.State[3]) ]XIO(q_AlarmActive)OTE(q_StartOK);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[Auto Mode Status]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[2]) ,XIC(Status.State[3]) ]XIO(CycleRunning)OTE(q_AutoMode);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[Auto Stopped Status]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[2]) ,XIC(Status.State[3]) ,XIC(Status.State[127]) ]XIO(CycleRunning)OTE(q_AutoStopped);]]>
</Text>
</Rung>
</RLLContent>
</Routine>

