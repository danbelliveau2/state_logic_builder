<Routines>

<Routine Name="R00_Main" Type="RLL">
<RLLContent>

<Rung Number="0" Type="N">
<Comment>
<![CDATA[Jump to Inputs]]>
</Comment>
<Text>
<![CDATA[JSR(R01_Inputs,0);]]>
</Text>
</Rung>

<Rung Number="1" Type="N">
<Comment>
<![CDATA[Jump to State Transitions]]>
</Comment>
<Text>
<![CDATA[JSR(R02_StateTransitions,0);]]>
</Text>
</Rung>

<Rung Number="2" Type="N">
<Comment>
<![CDATA[Jump to State Logic]]>
</Comment>
<Text>
<![CDATA[JSR(R03_StateLogic,0);]]>
</Text>
</Rung>
</RLLContent>
</Routine>

<Routine Name="R01_Inputs" Type="RLL">
<RLLContent>

<Rung Number="0" Type="N">
<Comment>
<![CDATA[All Stations Ready - All at home/wait position]]>
</Comment>
<Text>
<![CDATA[XIC(\S01_PartLoad.Status.State[1]) XIC(\S01_RobotLoad.Status.State[1]) XIC(\S04_PartLocate.Status.State[1]) XIC(\S06_LocationVerify.Status.State[1]) XIC(\S07_Reject1Unload.Status.State[1]) XIC(\S17_BarrelVerify.Status.State[1]) XIC(\S21_Reject2Unload.Status.State[1]) XIC(\S55_TemperatureVerify.Status.State[1]) XIC(\S56_WireFeed.Status.State[1]) XIC(\S61_WireFeedVerify.Status.State[1]) XIC(\S72_GoodPartUnload1.Status.State[1]) XIC(\S76_GoodPartUnload2.Status.State[1]) XIC(\S84_RejectPartUnload.Status.State[1]) OTE(Sup_AllStationsReady);]]>
</Text>
</Rung>

<Rung Number="1" Type="N">
<Comment>
<![CDATA[All Stations Stopped - All returned to home]]>
</Comment>
<Text>
<![CDATA[XIC(\S01_PartLoad.Status.State[1]) XIC(\S01_RobotLoad.Status.State[1]) XIC(\S04_PartLocate.Status.State[1]) XIC(\S06_LocationVerify.Status.State[1]) XIC(\S07_Reject1Unload.Status.State[1]) XIC(\S17_BarrelVerify.Status.State[1]) XIC(\S21_Reject2Unload.Status.State[1]) XIC(\S55_TemperatureVerify.Status.State[1]) XIC(\S56_WireFeed.Status.State[1]) XIC(\S61_WireFeedVerify.Status.State[1]) XIC(\S72_GoodPartUnload1.Status.State[1]) XIC(\S76_GoodPartUnload2.Status.State[1]) XIC(\S84_RejectPartUnload.Status.State[1]) OTE(Sup_AllStationsStopped);]]>
</Text>
</Rung>

<Rung Number="2" Type="N">
<Comment>
<![CDATA[Fault Detection - Any station timeout fault]]>
</Comment>
<Text>
<![CDATA[[XIC(\S01_PartLoad.Status.TimeoutFlt) ,XIC(\S01_RobotLoad.Status.TimeoutFlt) ,XIC(\S04_PartLocate.Status.TimeoutFlt) ,XIC(\S06_LocationVerify.Status.TimeoutFlt) ,XIC(\S07_Reject1Unload.Status.TimeoutFlt) ,XIC(\S17_BarrelVerify.Status.TimeoutFlt) ,XIC(\S21_Reject2Unload.Status.TimeoutFlt) ,XIC(\S55_TemperatureVerify.Status.TimeoutFlt) ,XIC(\S56_WireFeed.Status.TimeoutFlt) ,XIC(\S61_WireFeedVerify.Status.TimeoutFlt) ,XIC(\S72_GoodPartUnload1.Status.TimeoutFlt) ,XIC(\S76_GoodPartUnload2.Status.TimeoutFlt) ,XIC(\S84_RejectPartUnload.Status.TimeoutFlt)] OTE(Sup_FaultActive);]]>
</Text>
</Rung>
</RLLContent>
</Routine>

<Routine Name="R02_StateTransitions" Type="RLL">
<RLLContent>

<Rung Number="0" Type="N">
<Comment>
<![CDATA[Idle → Manual: Safety OK and Manual mode selected]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[1]) XIC(Sup_SafetyOK) XIC(Sup_ModeManual) MOV(4,Control.StateReg);]]>
</Text>
</Rung>

<Rung Number="1" Type="N">
<Comment>
<![CDATA[Idle → Auto Init: Safety OK and Auto mode selected]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[1]) XIC(Sup_SafetyOK) XIC(Sup_ModeAuto) MOV(7,Control.StateReg);]]>
</Text>
</Rung>

<Rung Number="2" Type="N">
<Comment>
<![CDATA[Manual → Idle: Mode deselected or safety lost]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[4]) [XIO(Sup_ModeManual) ,XIO(Sup_SafetyOK)] MOV(1,Control.StateReg);]]>
</Text>
</Rung>

<Rung Number="3" Type="N">
<Comment>
<![CDATA[Manual → Auto Init: Switch to auto mode]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[4]) XIC(Sup_SafetyOK) XIC(Sup_ModeAuto) MOV(7,Control.StateReg);]]>
</Text>
</Rung>

<Rung Number="4" Type="N">
<Comment>
<![CDATA[Auto Init → Auto Ready: All stations ready]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[7]) XIC(Sup_AllStationsReady) MOV(10,Control.StateReg);]]>
</Text>
</Rung>

<Rung Number="5" Type="N">
<Comment>
<![CDATA[Auto Init → Idle: Mode deselected or safety lost]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[7]) [XIO(Sup_ModeAuto) ,XIO(Sup_SafetyOK)] MOV(1,Control.StateReg);]]>
</Text>
</Rung>

<Rung Number="6" Type="N">
<Comment>
<![CDATA[Auto Ready → Cycle Stop: Cycle stop commanded]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[10]) XIC(Sup_CycleStopCmd) MOV(13,Control.StateReg);]]>
</Text>
</Rung>

<Rung Number="7" Type="N">
<Comment>
<![CDATA[Auto Ready → Faulted: Station fault detected]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[10]) XIC(Sup_FaultActive) MOV(16,Control.StateReg);]]>
</Text>
</Rung>

<Rung Number="8" Type="N">
<Comment>
<![CDATA[Auto Ready → Idle: Safety lost]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[10]) XIO(Sup_SafetyOK) MOV(1,Control.StateReg);]]>
</Text>
</Rung>

<Rung Number="9" Type="N">
<Comment>
<![CDATA[Cycle Stop → Idle: All stations stopped]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[13]) XIC(Sup_AllStationsStopped) MOV(1,Control.StateReg);]]>
</Text>
</Rung>

<Rung Number="10" Type="N">
<Comment>
<![CDATA[Cycle Stop → Faulted: Station fault during stop]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[13]) XIC(Sup_FaultActive) MOV(16,Control.StateReg);]]>
</Text>
</Rung>

<Rung Number="11" Type="N">
<Comment>
<![CDATA[Faulted → Idle: Fault reset with no active faults and safety OK]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[16]) XIC(Sup_FaultReset) XIO(Sup_FaultActive) XIC(Sup_SafetyOK) MOV(1,Control.StateReg);]]>
</Text>
</Rung>

<Rung Number="12" Type="N">
<Comment>
<![CDATA[State Engine AOI]]>
</Comment>
<Text>
<![CDATA[State_Engine_128Max(StateEngine,Control,Status,StateHistory);]]>
</Text>
</Rung>
</RLLContent>
</Routine>

<Routine Name="R03_StateLogic" Type="RLL">
<RLLContent>

<Rung Number="0" Type="N">
<Comment>
<![CDATA[Cycle Start Latch - Latch on cycle start command in Auto Ready]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[10]) XIC(Sup_CycleStartCmd) OTL(Sup_CycleStartLatch);]]>
</Text>
</Rung>

<Rung Number="1" Type="N">
<Comment>
<![CDATA[Cycle Start Delay Timer]]>
</Comment>
<Text>
<![CDATA[XIC(Sup_CycleStartLatch) TON(Sup_CycleStartDelay,?,?);]]>
</Text>
</Rung>

<Rung Number="2" Type="N">
<Comment>
<![CDATA[Machine Running - Cycle start latched and delay complete]]>
</Comment>
<Text>
<![CDATA[XIC(Sup_CycleStartLatch) XIC(Sup_CycleStartDelay.DN) OTE(Sup_MachineRunning);]]>
</Text>
</Rung>

<Rung Number="3" Type="N">
<Comment>
<![CDATA[Cycle Stop - Unlatch cycle start on Cycle Stop state]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[13]) OTU(Sup_CycleStartLatch);]]>
</Text>
</Rung>

<Rung Number="4" Type="N">
<Comment>
<![CDATA[Fault - Unlatch cycle start on Faulted state]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[16]) OTU(Sup_CycleStartLatch);]]>
</Text>
</Rung>

<Rung Number="5" Type="N">
<Comment>
<![CDATA[Stacklight Green - Machine is running]]>
</Comment>
<Text>
<![CDATA[XIC(Sup_MachineRunning) OTE(Sup_StackGreen);]]>
</Text>
</Rung>

<Rung Number="6" Type="N">
<Comment>
<![CDATA[Stacklight Yellow - Manual mode or Auto Init]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[4]) ,XIC(Status.State[7])] OTE(Sup_StackYellow);]]>
</Text>
</Rung>

<Rung Number="7" Type="N">
<Comment>
<![CDATA[Stacklight Red - Faulted or E-Stop active]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[16]) ,XIC(Sup_EStopActive)] OTE(Sup_StackRed);]]>
</Text>
</Rung>

<Rung Number="8" Type="N">
<Comment>
<![CDATA[Stuck In Run Watchdog - Timer starts when running but stations not ready]]>
</Comment>
<Text>
<![CDATA[XIC(Sup_MachineRunning) XIO(Sup_AllStationsReady) TON(Sup_StuckInRunTimer,?,?);]]>
</Text>
</Rung>

<Rung Number="9" Type="N">
<Comment>
<![CDATA[Stuck In Run Fault - Latch fault if watchdog expires]]>
</Comment>
<Text>
<![CDATA[XIC(Sup_StuckInRunTimer.DN) OTL(Sup_FaultActive);]]>
</Text>
</Rung>
</RLLContent>
</Routine>
</Routines>
</Program>
