<LocalTag Name="HistoryArraySize" DataType="SINT" Radix="Decimal" ExternalAccess="None">
<Description>
<![CDATA[Size of state history array]]>
</Description>
<DefaultData Format="L5K">
<![CDATA[0]]>
</DefaultData>
<DefaultData Format="Decorated">
<DataValue DataType="SINT" Radix="Decimal" Value="0"/>
</DefaultData>
</LocalTag>
</LocalTags>
<Routines>
<Routine Name="Logic" Type="ST">
<STContent>
<Line Number="0">
<![CDATA[StateDurationTimer.Reset := 0;]]>
</Line>
<Line Number="1">
<![CDATA[StateDurationTimer.PRE := 2147483647;]]>
</Line>
<Line Number="2">
<![CDATA[SIZE(StateHistoryArray,0,HistoryArraySize);]]>
</Line>
<Line Number="3">
<![CDATA[]]>
</Line>
<Line Number="4">
<![CDATA[TONR(StateDurationTimer);]]>
</Line>
<Line Number="5">
<![CDATA[]]>
</Line>
<Line Number="6">
<![CDATA[COP(StateLogicStatus, localStatus, 1); //localStatus used so all Status updates at the same time, at the end of this code.]]>
</Line>
<Line Number="7">
<![CDATA[If (StateLogicControl.StateReg = StateReg_Prev) THEN]]>
</Line>
<Line Number="8">
<![CDATA[	//Previous State equal to Current State: Still in the same state as the last scan.]]>
</Line>
<Line Number="9">
<![CDATA[	localStatus.StateChangeOccurred_OS := 0;]]>
</Line>
<Line Number="10">
<![CDATA[]]>
</Line>
<Line Number="11">
<![CDATA[	//State Duration Timer]]>
</Line>
<Line Number="12">
<![CDATA[	StateDurationTimer.TimerEnable := 1;]]>
</Line>
<Line Number="13">
<![CDATA[]]>
</Line>
<Line Number="14">
<![CDATA[	//State Fault Timer]]>
</Line>
<Line Number="15">
<![CDATA[	IF (StateDurationTimer.ACC >= StateLogicControl.FaultTime ) THEN]]>
</Line>
<Line Number="16">
<![CDATA[		localStatus.TimeoutFlt := 1;]]>
</Line>
<Line Number="17">
<![CDATA[	ELSE]]>
</Line>
<Line Number="18">
<![CDATA[		localStatus.TimeoutFlt := 0;]]>
</Line>
<Line Number="19">
<![CDATA[	END_IF;]]>
</Line>
<Line Number="20">
<![CDATA[]]>
</Line>
<Line Number="21">
<![CDATA[]]>
</Line>
<Line Number="22">
<![CDATA[	//State Transition Timer]]>
</Line>
<Line Number="23">
<![CDATA[	IF (StateDurationTimer.ACC >= StateLogicControl.TransitionTime) THEN]]>
</Line>
<Line Number="24">
<![CDATA[		localStatus.TransitionTimerDone := 1;]]>
</Line>
<Line Number="25">
<![CDATA[	ELSE]]>
</Line>
<Line Number="26">
<![CDATA[		localStatus.TransitionTimerDone := 0;]]>
</Line>
<Line Number="27">
<![CDATA[	END_IF;]]>
</Line>
<Line Number="28">
<![CDATA[ELSE]]>
</Line>
<Line Number="29">
<![CDATA[	//Previous State not Current State: State Change Occurred.]]>
</Line>
<Line Number="30">
<![CDATA[	localStatus.StateChangeOccurred_OS := 1;]]>
</Line>
<Line Number="31">
<![CDATA[	localStatus.PreviousState := StateReg_Prev;]]>
</Line>
<Line Number="32">
<![CDATA[	StateReg_Prev := StateLogicControl.StateReg;]]>
</Line>
<Line Number="33">
<![CDATA[	]]>
</Line>
<Line Number="34">
<![CDATA[	//Shift state history array and store last state in index 0]]>
</Line>
<Line Number="35">
<![CDATA[	if HistoryArraySize > 1 then //history array size of 1 would cause an array index out of bounds controller fault]]>
</Line>
<Line Number="36">
<![CDATA[		for i := HistoryArraySize-1 to 1 by -1 do]]>
</Line>
<Line Number="37">
<![CDATA[			StateHistoryArray[i] := StateHistoryArray[i-1];]]>
</Line>
<Line Number="38">
<![CDATA[		end_for;]]>
</Line>
<Line Number="39">
<![CDATA[	end_if;]]>
</Line>
<Line Number="40">
<![CDATA[	StateHistoryArray[0] := StateReg_Prev;]]>
</Line>
<Line Number="41">
<![CDATA[]]>
</Line>
<Line Number="42">
<![CDATA[	StateDurationTimer.Reset := 1;]]>
</Line>
<Line Number="43">
<![CDATA[	StateDurationTimer.TimerEnable := 0;]]>
</Line>
<Line Number="44">
<![CDATA[	//Default to DINT Max value.]]>
</Line>
<Line Number="45">
<![CDATA[	//EnaTransitionTimer and EnaFaultTimer bits kept for legacy compatibility]]>
</Line>
<Line Number="46">
<![CDATA[	StateLogicControl.TransitionTime := 2147483647;]]>
</Line>
<Line Number="47">
<![CDATA[	StateLogicControl.FaultTime := 2147483647;]]>
</Line>
<Line Number="48">
<![CDATA[]]>
</Line>
<Line Number="49">
<![CDATA[	localStatus.TimeoutFlt := 0;]]>
</Line>
<Line Number="50">
<![CDATA[	localStatus.TransitionTimerDone := 0;]]>
</Line>
<Line Number="51">
<![CDATA[END_IF;]]>
</Line>
<Line Number="52">
<![CDATA[]]>
</Line>
<Line Number="53">
<![CDATA[//Set the State Bit, clear all other bits.]]>
</Line>
<Line Number="54">
<![CDATA[FOR i := 0 TO 127 DO]]>
</Line>
<Line Number="55">
<![CDATA[	localStatus.State[i] := 0;]]>
</Line>
<Line Number="56">
<![CDATA[END_FOR;]]>
</Line>
<Line Number="57">
<![CDATA[localStatus.State[StateLogicControl.StateReg] := 1;]]>
</Line>
<Line Number="58">
<![CDATA[]]>
</Line>
<Line Number="59">
<![CDATA[COP(localStatus, StateLogicStatus, 1);]]>
</Line>
<Line Number="60">
<![CDATA[]]>
</Line>
</STContent>
</Routine>
</Routines>
<Dependencies>
<Dependency Type="DataType" Name="StateLogicStatus"/>
<Dependency Type="DataType" Name="StateLogicControl"/>
</Dependencies>
</AddOnInstructionDefinition>
<AddOnInstructionDefinition Name="AOI_RangeCheck" Class="Standard" Revision="0.1" ExecutePrescan="false" ExecutePostscan="false" ExecuteEnableInFalse="false" CreatedDate="2010-03-29T16:58:02.278Z" CreatedBy="SDC" EditedDate="2024-01-01T00:00:00.000Z" EditedBy="SDC" SoftwareRevision="v35.00">
