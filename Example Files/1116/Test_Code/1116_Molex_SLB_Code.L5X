<Routines>

<Routine Name="R00_Main" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Subroutine Calls]]>
</Comment>
<Text>
<![CDATA[JSR(R01_Inputs,0);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[JSR(R02_StateTransitions,0);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[JSR(R03_StateLogic,0);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[JSR(R20_Alarms,0);]]>
</Text>
</Rung>
</RLLContent>
</Routine>

<Routine Name="R01_Inputs" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Mapped Inputs from Supervisor]]>
</Comment>
<Text>
<![CDATA[NOP();]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Text>
<![CDATA[XIC(\Supervisor.q_ManualMode)XIO(HMI_LocalManualOverride)OTE(ManualMode);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Text>
<![CDATA[XIC(\Supervisor.q_SafetyOK)OTE(SafetyOK);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Text>
<![CDATA[XIC(\Supervisor.q_FaultReset)OTE(FaultReset);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Text>
<![CDATA[[XIC(\Supervisor.q_CycleStartLatch) ,XIC(HMI_LocalManualOverride) ]OTE(CycleRunning);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Text>
<![CDATA[XIO(\Supervisor.q_CycleStartLatch)OTE(CycleStopping);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Text>
<![CDATA[XIC(\Supervisor.q_CycleStopped)ONS(ONS.0)XIO(Status.State[2])XIO(Status.State[3])OTE(CycleStopped);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Initialization]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[124])OTE(Initialized);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[Single Step Logic]]>
</Comment>
<Text>
<![CDATA[XIC(LocalSS)OTE(SS);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Text>
<![CDATA[[XIO(SS) ,XIC(LocalSSONS) ONS(ONS.1) ]OTE(SS_OK);]]>
</Text>
</Rung>
</RLLContent>
</Routine>

<Routine Name="R02_StateTransitions" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[State 0: Safety Stop]]>
</Comment>
<Text>
<![CDATA[[XIO(SafetyOK) ,XIC(S:FS) ][ONS(ONS.3) LIMIT(4,Control.StateReg,99) MOVE(Control.StateReg,SafetyStopState) MOVE(Control.StateReg,RestartState) ,MOVE(0,Control.StateReg) ];]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[State 1: Manual Mode]]>
</Comment>
<Text>
<![CDATA[XIC(ManualMode)MOVE(1,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[State 2: Auto Idle NOT Ready]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[0]) XIC(SafetyOK) XIO(ManualMode) ,XIC(Status.State[1]) XIO(ManualMode) ,XIC(Status.State[127]) XIC(FaultReset) ,XIC(Status.State[124]) ]MOVE(2,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[State 3: Auto Idle Ready]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[2]) XIC(Initialized) ,XIC(Status.State[25]) ]MOVE(3,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[State 127: Fault]]>
</Comment>
<Text>
<![CDATA[XIC(q_AlarmActive)[ONS(ONS.2) LIMIT(4,Control.StateReg,99) MOVE(Control.StateReg,FaultState) MOVE(Control.StateReg,RestartState) ,MOVE(127,Control.StateReg) ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[State 4: Move Wire_Feed X to Pick, Move Wire_Feed Z to Retract, Move Wire_Feed Feed to Home]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[3])XIC(CycleRunning)XIC(MAM_Wire_FeedX.PC)XIC(MAM_Wire_FeedZ.PC)XIC(MAM_Wire_FeedFeed.PC)MOVE(4,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[State 7: Branch: Temperature_Verify_Inspect]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[4])XIC(MAM_Wire_FeedX.PC)XIC(Wire_FeedXPickRC.In_Range)XIC(MAM_Wire_FeedZ.PC)XIC(Wire_FeedZRetractRC.In_Range)XIC(MAM_Wire_FeedFeed.PC)XIC(Wire_FeedFeedHomeRC.In_Range)MOVE(7,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[State 10: Move Wire_Feed Z to Top_of_Part, Move Wire_Feed X to Start [Pass]]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[7])XIC(PartTracking.Temperature_Verify_Inspect)MOVE(10,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[State 25: Cycle Complete [Fail]]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[7])XIO(PartTracking.Temperature_Verify_Inspect)MOVE(25,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[State 13: Wait WireMelt]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[10])XIC(MAM_Wire_FeedZ.PC)XIC(Wire_FeedZTop_of_PartRC.In_Range)XIC(MAM_Wire_FeedX.PC)XIC(Wire_FeedXStartRC.In_Range)MOVE(13,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[State 16: Increment Wire_Feed X — Along_Seam (10mm), Move Wire_Feed Feed to Feed]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[13])TON(WireMelt,?,?)XIC(WireMelt.DN)MOVE(16,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Comment>
<![CDATA[State 19: Move Wire_Feed Z to Retract]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[16])XIC(MAM_Wire_FeedX.PC)XIC(MAM_Wire_FeedFeed.PC)XIC(Wire_FeedFeedFeedRC.In_Range)MOVE(19,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[State 22: Move Wire_Feed X to Start]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[19])XIC(MAM_Wire_FeedZ.PC)XIC(Wire_FeedZRetractRC.In_Range)MOVE(22,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="13" Type="N">
<Comment>
<![CDATA[State 25: Cycle Complete]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[22])XIC(MAM_Wire_FeedX.PC)XIC(Wire_FeedXStartRC.In_Range)MOVE(25,Control.StateReg);]]>
</Text>
</Rung>
<Rung Number="14" Type="N">
<Comment>
<![CDATA[Cycle Time Accumulator]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[4]) ,XIC(Status.State[7]) ,XIC(Status.State[10]) ,XIC(Status.State[13]) ,XIC(Status.State[16]) ,XIC(Status.State[19]) ,XIC(Status.State[22]) ,XIC(Status.State[25])]RTO(CycleTimer,?,?);]]>
</Text>
</Rung>
<Rung Number="15" Type="N">
<Comment>
<![CDATA[Cycle Time Compute + Reset]]>
</Comment>
<Text>
<![CDATA[XIC(Status.State[3])XIC(CycleRunning)ONS(ONS.4)[DIV(CycleTimer.ACC,1000.0,p_CycleTime) ,MOVE(0,CycleTimer.ACC) ];]]>
</Text>
</Rung>
<Rung Number="16" Type="N">
<Comment>
<![CDATA[Fault Timer Enable]]>
</Comment>
<Text>
<![CDATA[LIMIT(4,Control.StateReg,59)XIO(SS)[MOVE(5000,Control.FaultTime) ,OTE(Control.EnaFaultDetect) ];]]>
</Text>
</Rung>
<Rung Number="17" Type="N">
<Comment>
<![CDATA[State Engine]]>
</Comment>
<Text>
<![CDATA[State_Engine_128Max(StateEngine,Control,Status,StateHistory);]]>
</Text>
</Rung>
</RLLContent>
</Routine>

<Routine Name="R03_StateLogic" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Part Tracking: Clear All at Cycle Start]]>
</Comment>
<Text>
<![CDATA[XIC(CycleRunning)ONS(ONS.5)OTU(PartTracking.Location_Verify_Inspect)OTU(PartTracking.Location_Verify_Inspect_X_Offset)OTU(PartTracking.Temperature_Verify_Inspect);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Wire_Feed X Position Selection]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[4]) [MOVE(p_Wire_FeedXPick,Wire_FeedX_MotionParam.Position) ,MOVE(0,Wire_FeedX_MotionParam.MoveType) ] ,XIC(Status.State[10]) [MOVE(p_Wire_FeedXStart,Wire_FeedX_MotionParam.Position) ,MOVE(0,Wire_FeedX_MotionParam.MoveType) ] ,XIC(Status.State[16]) [MOVE(p_Wire_FeedXIncrDist,Wire_FeedX_MotionParam.Position) ,MOVE(1,Wire_FeedX_MotionParam.MoveType) ] ,XIC(Status.State[22]) [MOVE(p_Wire_FeedXStart,Wire_FeedX_MotionParam.Position) ,MOVE(0,Wire_FeedX_MotionParam.MoveType) ] ];]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Wire_Feed X Motion Command]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[4]) ,XIC(Status.State[10]) ,XIC(Status.State[16]) ,XIC(Status.State[22])]MAM(a{axisNum}_Wire_FeedX,MAM_Wire_FeedX,Wire_FeedX_MotionParam.MoveType,Wire_FeedX_MotionParam.Position,Wire_FeedX_MotionParam.Speed,Units per sec,Wire_FeedX_MotionParam.Accel,Units per sec2,Wire_FeedX_MotionParam.Decel,Units per sec2,Trapezoidal,0,0,Units per sec3,Disabled,0,0,None,0,0);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Wire_Feed X Position Monitoring]]>
</Comment>
<Text>
<![CDATA[[AOI_RangeCheck(Wire_FeedXStartRC,p_Wire_FeedXStart,0.5,a{axisNum}_Wire_FeedX.ActualPosition) ,AOI_RangeCheck(Wire_FeedXAlong_SeamRC,p_Wire_FeedXAlong_Seam,0.5,a{axisNum}_Wire_FeedX.ActualPosition) ];]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Wire_Feed Z Position Selection]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[4]) [MOVE(p_Wire_FeedZRetract,Wire_FeedZ_MotionParam.Position) ,MOVE(0,Wire_FeedZ_MotionParam.MoveType) ] ,XIC(Status.State[10]) [MOVE(p_Wire_FeedZTop_of_Part,Wire_FeedZ_MotionParam.Position) ,MOVE(0,Wire_FeedZ_MotionParam.MoveType) ] ,XIC(Status.State[19]) [MOVE(p_Wire_FeedZRetract,Wire_FeedZ_MotionParam.Position) ,MOVE(0,Wire_FeedZ_MotionParam.MoveType) ] ];]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Wire_Feed Z Motion Command]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[4]) ,XIC(Status.State[10]) ,XIC(Status.State[19])]MAM(a{axisNum}_Wire_FeedZ,MAM_Wire_FeedZ,Wire_FeedZ_MotionParam.MoveType,Wire_FeedZ_MotionParam.Position,Wire_FeedZ_MotionParam.Speed,Units per sec,Wire_FeedZ_MotionParam.Accel,Units per sec2,Wire_FeedZ_MotionParam.Decel,Units per sec2,Trapezoidal,0,0,Units per sec3,Disabled,0,0,None,0,0);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Wire_Feed Z Position Monitoring]]>
</Comment>
<Text>
<![CDATA[[AOI_RangeCheck(Wire_FeedZTop_of_PartRC,p_Wire_FeedZTop_of_Part,0.5,a{axisNum}_Wire_FeedZ.ActualPosition) ,AOI_RangeCheck(Wire_FeedZRetractRC,p_Wire_FeedZRetract,0.5,a{axisNum}_Wire_FeedZ.ActualPosition) ];]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Wire_Feed Feed Position Selection]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[4]) [MOVE(p_Wire_FeedFeedHome,Wire_FeedFeed_MotionParam.Position) ,MOVE(0,Wire_FeedFeed_MotionParam.MoveType) ] ,XIC(Status.State[16]) [MOVE(p_Wire_FeedFeedFeed,Wire_FeedFeed_MotionParam.Position) ,MOVE(0,Wire_FeedFeed_MotionParam.MoveType) ] ];]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[Wire_Feed Feed Motion Command]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[4]) ,XIC(Status.State[16])]MAM(a{axisNum}_Wire_FeedFeed,MAM_Wire_FeedFeed,Wire_FeedFeed_MotionParam.MoveType,Wire_FeedFeed_MotionParam.Position,Wire_FeedFeed_MotionParam.Speed,Units per sec,Wire_FeedFeed_MotionParam.Accel,Units per sec2,Wire_FeedFeed_MotionParam.Decel,Units per sec2,Trapezoidal,0,0,Units per sec3,Disabled,0,0,None,0,0);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[Wire_Feed Feed Position Monitoring]]>
</Comment>
<Text>
<![CDATA[[AOI_RangeCheck(Wire_FeedFeedFeedRC,p_Wire_FeedFeedFeed,0.5,a{axisNum}_Wire_FeedFeed.ActualPosition) ];]]>
</Text>
</Rung>
<Rung Number="10" Type="N">
<Comment>
<![CDATA[Station Start OK]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[1]) ,XIC(Status.State[2]) ,XIC(Status.State[3]) ]XIO(q_AlarmActive)OTE(q_StartOK);]]>
</Text>
</Rung>
<Rung Number="11" Type="N">
<Comment>
<![CDATA[Auto Mode Status]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[2]) ,XIC(Status.State[3]) ]XIO(CycleRunning)OTE(q_AutoMode);]]>
</Text>
</Rung>
<Rung Number="12" Type="N">
<Comment>
<![CDATA[Auto Stopped Status]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[2]) ,XIC(Status.State[3]) ,XIC(Status.State[127]) ]XIO(CycleRunning)OTE(q_AutoStopped);]]>
</Text>
</Rung>
</RLLContent>
</Routine>

<Routine Name="R20_Alarms" Type="RLL">
<RLLContent>
<Rung Number="0" Type="N">
<Comment>
<![CDATA[Wire_Feed X Motion Timeout]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[4])TON(SensorTimer[0],?,?)XIC(SensorTimer[0].DN) ,XIC(Alarm[0].Active) XIO(FaultReset) ]OTE(Alarm[0].Active);]]>
</Text>
</Rung>
<Rung Number="1" Type="N">
<Comment>
<![CDATA[Wire_Feed Z Motion Timeout]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[4])TON(SensorTimer[1],?,?)XIC(SensorTimer[1].DN) ,XIC(Alarm[1].Active) XIO(FaultReset) ]OTE(Alarm[1].Active);]]>
</Text>
</Rung>
<Rung Number="2" Type="N">
<Comment>
<![CDATA[Wire_Feed Feed Motion Timeout]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[4])TON(SensorTimer[2],?,?)XIC(SensorTimer[2].DN) ,XIC(Alarm[2].Active) XIO(FaultReset) ]OTE(Alarm[2].Active);]]>
</Text>
</Rung>
<Rung Number="3" Type="N">
<Comment>
<![CDATA[Wire_Feed Z Motion Timeout]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[10])TON(SensorTimer[3],?,?)XIC(SensorTimer[3].DN) ,XIC(Alarm[3].Active) XIO(FaultReset) ]OTE(Alarm[3].Active);]]>
</Text>
</Rung>
<Rung Number="4" Type="N">
<Comment>
<![CDATA[Wire_Feed X Motion Timeout]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[10])TON(SensorTimer[4],?,?)XIC(SensorTimer[4].DN) ,XIC(Alarm[4].Active) XIO(FaultReset) ]OTE(Alarm[4].Active);]]>
</Text>
</Rung>
<Rung Number="5" Type="N">
<Comment>
<![CDATA[Wire_Feed X Motion Timeout]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[16])TON(SensorTimer[5],?,?)XIC(SensorTimer[5].DN) ,XIC(Alarm[5].Active) XIO(FaultReset) ]OTE(Alarm[5].Active);]]>
</Text>
</Rung>
<Rung Number="6" Type="N">
<Comment>
<![CDATA[Wire_Feed Feed Motion Timeout]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[16])TON(SensorTimer[6],?,?)XIC(SensorTimer[6].DN) ,XIC(Alarm[6].Active) XIO(FaultReset) ]OTE(Alarm[6].Active);]]>
</Text>
</Rung>
<Rung Number="7" Type="N">
<Comment>
<![CDATA[Wire_Feed Z Motion Timeout]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[19])TON(SensorTimer[7],?,?)XIC(SensorTimer[7].DN) ,XIC(Alarm[7].Active) XIO(FaultReset) ]OTE(Alarm[7].Active);]]>
</Text>
</Rung>
<Rung Number="8" Type="N">
<Comment>
<![CDATA[Wire_Feed X Motion Timeout]]>
</Comment>
<Text>
<![CDATA[[XIC(Status.State[22])TON(SensorTimer[8],?,?)XIC(SensorTimer[8].DN) ,XIC(Alarm[8].Active) XIO(FaultReset) ]OTE(Alarm[8].Active);]]>
</Text>
</Rung>
<Rung Number="9" Type="N">
<Comment>
<![CDATA[Program Alarm Handler]]>
</Comment>
<Text>
<![CDATA[ProgramAlarmHandler(ProgramFaultHandler,\Alarms.p_ProgramID,Alarm,\Alarms.p_Active,\Alarms.p_History,g_CPUDateTime,q_AlarmActive,q_WarningActive);]]>
</Text>
</Rung>
